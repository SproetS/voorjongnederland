---
import SiteFooter from '../components/SiteFooter.astro';

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  navItems?: NavItem[];
  featureImage?: string;
  featureImageAlt?: string;
  showFeatureImage?: boolean;
  pageClass?: string;
  currentPath?: string;
}

const {
  title,
  description = 'Voor Jong Nederland',
  navItems = [],
  featureImage,
  featureImageAlt,
  showFeatureImage = false,
  pageClass,
  currentPath = Astro.url.pathname,
} = Astro.props;

---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/assets/logo-klein.png" />
    <link rel="apple-touch-icon" href="/assets/logo-klein.png" />
    <title>{title} | Voor Jong Nederland</title>
    <meta name="description" content={description} />
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main">Ga naar inhoud</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="brand-wrap">
          <a class="brand" href="/" aria-label="Voor Jong Nederland">
            <img src="/assets/logo-klein.png" alt="Voor Jong Nederland" width="132" height="63" loading="eager" decoding="async" />
          </a>
        </div>
        {showFeatureImage && featureImage ? (
          <div class="feature-wrap">
            <img src={featureImage} alt={featureImageAlt ?? ''} loading="eager" decoding="async" />
          </div>
        ) : (
          <div class="feature-empty" aria-hidden="true"></div>
        )}
      </header>

      <main id="main" class="site-main">
        <slot />
      </main>

      <SiteFooter navItems={navItems} currentPath={currentPath} />
    </div>
  </body>
</html>

<style>
  @font-face {
    font-family: 'GAP Zuid VG';
    src: url('/fonts/GAPZuidVG-Regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'GAP Zuid VG';
    src: url('/fonts/GAPZuidVG-Italic.woff2') format('woff2');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: 'GAP Zuid VG';
    src: url('/fonts/GAPZuidVG-Bold.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'GAP Zuid VG';
    src: url('/fonts/GAPZuidVG-BoldItalic.woff2') format('woff2');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  :root,
  .voor-jong-nederland {
    --blauw-1: #eeeeee;
    --blauw-2: #72a9cf;
    --blauw-3: #195575;
    --rood-1: #d4c9b8;
    --rood-2: #f7714d;
    --rood-3: #8f2c1e;
    --groen-1: #c3c47b;
    --groen-2: #7f8940;
    --groen-3: #5e584c;
  }

  @supports (color: color(display-p3 1 1 1)) {
    :root,
    .voor-jong-nederland {
      --blauw-1: color(display-p3 0.933 0.933 0.933 / 1);
      --blauw-2: color(display-p3 0.446 0.665 0.81 / 1);
      --blauw-3: color(display-p3 0.098 0.334 0.458 / 1);
      --rood-1: color(display-p3 0.831 0.787 0.722 / 1);
      --rood-2: color(display-p3 0.967 0.444 0.302 / 1);
      --rood-3: color(display-p3 0.561 0.171 0.119 / 1);
      --groen-1: color(display-p3 0.764 0.769 0.484 / 1);
      --groen-2: color(display-p3 0.498 0.539 0.251 / 1);
      --groen-3: color(display-p3 0.369 0.344 0.297 / 1);
    }
  }

  :root {
    --grid-y: 12px;
    --grid-x: 16px;
    --surface: #ffffff;
    --border: #a7a7a7;
    --text: var(--groen-3);
    --link: var(--blauw-3);
    --muted: #6f6f6f;
    --hero-gradient: linear-gradient(140deg, var(--blauw-2), var(--groen-1));
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 18px;
  }

  body {
    margin: 0;
    background: var(--surface);
    color: var(--text);
    font-family: 'GAP Zuid VG', 'Segoe UI', sans-serif;
    font-size: 1rem;
    line-height: calc(var(--grid-y) * 2);
    font-variant-ligatures: common-ligatures discretionary-ligatures contextual;
    font-feature-settings: 'dlig' 1;
  }

  a {
    color: var(--link);
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--surface);
    color: var(--text);
    padding: calc(var(--grid-y) / 2) calc(var(--grid-x) / 2);
    border: 1px solid var(--border);
  }

  .skip-link:focus {
    left: calc(var(--grid-x) / 2);
    top: calc(var(--grid-y) / 2);
    z-index: 20;
  }

  .site-shell {
    width: min(calc(100% - (var(--grid-x) * 2)), 1248px);
    margin: 0 auto calc(var(--grid-y) * 2);
    background: var(--surface);
    min-height: calc(100vh - (var(--grid-y) * 4));
    display: flex;
    flex-direction: column;
  }

  .site-header {
    position: relative;
    background: var(--surface);
    overflow: visible;
  }

  .brand-wrap {
    position: absolute;
    top: calc(var(--grid-y) * 1);
    left: calc(50% - 50vw + 32px);
    z-index: 3;
    min-height: 0;
    padding: 0;
    display: block;
  }

  .brand {
    display: inline-block;
  }

  .brand img {
    display: block;
    width: clamp(108px, 20vw, 132px);
    height: auto;
    filter: drop-shadow(0 2px 5px rgb(0 0 0 / 0.28));
  }

  .feature-wrap {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: rgb(0 0 0 / 0.8);
  }

  .feature-wrap img {
    display: block;
    width: min(100vw, 1248px);
    aspect-ratio: 16 / 9;
    margin-inline: auto;
    object-fit: cover;
    object-position: center;
  }

  .feature-empty {
    min-height: calc(var(--grid-y) * 20);
    background: var(--surface);
  }

  .site-main {
    flex: 1;
    padding: calc(var(--grid-y) * 2) calc(var(--grid-x) * 2);
  }

  :global(body.page-news-detail .site-main),
  :global(body.page-podcasts-detail .site-main) {
    display: flex;
    flex-direction: column;
  }

  :global(.detail-page-shell) {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  :global(.site-main a) {
    color: var(--blauw-2);
    text-decoration: none;
  }

  :global(.site-main a:visited) {
    color: rgb(0 0 0 / 0.6);
  }

  :global(.article-body),
  :global(.news-item),
  :global(.news-item p),
  :global(.article-body p),
  :global(.article-body li) {
    overflow-wrap: break-word;
    word-break: normal;
    hyphens: auto;
  }


  :global(.content-column) {
    width: min(100%, 840px);
    margin-inline: auto;
  }

  :global(.content-column--wide) {
    width: min(100%, 1248px);
    margin-inline: auto;
  }

  :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :global(.lead) {
    margin: calc(var(--grid-y) * 2) 0 0;
    font-size: 1rem;
    line-height: calc(var(--grid-y) * 2);
  }

  :global(.article-header) {
    margin-bottom: calc(var(--grid-y) * 2);
  }

  :global(h1) {
    margin: 0 0 calc(var(--grid-y) * 2);
    font-size: 2.333333rem;
    line-height: calc(var(--grid-y) * 4);
  }

  :global(h2) {
    margin: 0 0 calc(var(--grid-y) * 1);
    font-size: 1.666667rem;
    line-height: calc(var(--grid-y) * 3);
  }

  :global(h3) {
    margin: 0 0 calc(var(--grid-y) * 1);
    font-size: 1.333333rem;
    line-height: calc(var(--grid-y) * 2);
  }

  :global(p),
  :global(ul),
  :global(ol),
  :global(blockquote),
  :global(table),
  :global(figure),
  :global(iframe),
  :global(audio) {
    margin: 0 0 calc(var(--grid-y) * 2);
  }

  :global(img),
  :global(video) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 0 calc(var(--grid-y) * 2);
  }

  :global(ul),
  :global(ol) {
    padding-left: calc(var(--grid-x) * 1.5);
  }

  :global(table) {
    width: 100%;
    border-collapse: collapse;
  }

  :global(td),
  :global(th) {
    padding: calc(var(--grid-y) * 1) calc(var(--grid-x) * 0.5);
    vertical-align: top;
  }

  :global(iframe) {
    width: 100%;
    border: 0;
    aspect-ratio: 16 / 9;
  }

  :global(.meta) {
    margin: 0 0 calc(var(--grid-y) * 1);
    font-size: 0.666667rem;
    line-height: 1;
    color: var(--muted);
  }

  :global(.read-more) {
    text-decoration: none;
    font-size: 0.666667rem;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  :global(.page-default h1),
  :global(.page-news-detail h1),
  :global(.page-podcasts-detail h1) {
    color: var(--rood-2);
  }

  :global(.page-news-overview h1),
  :global(.page-news-overview h2),
  :global(.page-news-overview h2 a) {
    color: var(--blauw-2);
  }


  :global(.news-list) {
    display: grid;
    gap: calc(var(--grid-y) * 4);
  }

  :global(.news-list--narrow) {
    width: min(100%, 850px);
    margin-inline: auto;
  }

  :global(.news-item) {
    padding: 0;
    border: 0;
  }

  :global(.news-item h2) {
    margin-bottom: calc(var(--grid-y) * 1);
  }

  :global(.news-item h2 a) {
    text-decoration: none;
  }

  :global(.news-item .read-more) {
    display: block;
    margin-top: calc(var(--grid-y) * 1);
    text-align: right;
    color: var(--blauw-2);
  }

  :global(.news-item .read-more:visited) {
    color: var(--blauw-2);
  }

  :global(.podcast-grid) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    column-gap: var(--grid-x);
    row-gap: calc(var(--grid-y) * 2);
    margin-bottom: calc(var(--grid-y) * 2);
  }

  :global(.podcast-card) {
    display: block;
    aspect-ratio: 1 / 1;
    background: #afafaf;
    overflow: hidden;
  }

  :global(.podcast-card img) {
    margin: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.podcast-card span) {
    display: none;
  }

  :global(.podcast-detail-media img) {
    margin: 0;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  :global(.podcast-audio) {
    width: 100%;
    margin: calc(var(--grid-y) * 1) 0 calc(var(--grid-y) * 2);
  }

  :global(.article-body > :last-child) {
    margin-bottom: 0;
  }

  :global(.article-body script) {
    display: none;
  }

  @media (max-width: 56rem) {
    .site-shell {
      width: calc(100% - (var(--grid-x) * 1.5));
      margin: 0 auto var(--grid-y);
    }

    .site-main {
      padding: calc(var(--grid-y) * 2) var(--grid-x);
    }

    :global(.content-column),
    :global(.content-column--wide) {
      width: 100%;
    }

    :global(h1) {
      font-size: 2rem;
      line-height: calc(var(--grid-y) * 3);
    }

    :global(h2) {
      font-size: 1.333333rem;
      line-height: calc(var(--grid-y) * 2);
    }


    :global(.podcast-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 36rem) {
    .site-shell {
      width: calc(100% - var(--grid-x));
    }

    .brand-wrap {
      top: calc(var(--grid-y) * 1);
      left: calc(50% - 50vw + 32px);
    }

    .brand img {
      width: 94px;
    }

    .site-main {
      padding: var(--grid-y) calc(var(--grid-x) * 0.75);
    }



  }
</style>
