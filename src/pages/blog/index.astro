---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getMainNavItems } from '../../lib/navigation';

const navItems = await getMainNavItems();

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<Layout
  title="Nieuws"
  description="Nieuws en updates van Voor Jong Nederland"
  navItems={navItems}
  pageClass="page-news-overview"
  currentPath="/nieuws/"
>
  <section class="news-list news-list--narrow">
    <h1 class="sr-only">Nieuws</h1>

    {posts.length === 0 ? (
      <article class="news-item">
        <p>Er zijn nog geen nieuwsberichten.</p>
      </article>
    ) : (
      posts.map((post) => (
        <article class="news-item">
          <h2><a href={`/nieuws/${post.id}/`}>{post.data.title}</a></h2>
          <p class="meta">
            {post.data.publishDate.toLocaleDateString('nl-NL', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </p>
          {post.data.excerpt && <p>{post.data.excerpt}</p>}
          <a class="read-more" href={`/nieuws/${post.id}/`}>lees verder →</a>
        </article>
      ))
    )}
  </section>
</Layout>
